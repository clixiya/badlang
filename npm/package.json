{
  "name": "badlang",
  "version": "1.0.1",
  "description": "Cross-platform BAD CLI wrapper that downloads the correct binary from GitHub releases.",
  "license": "MIT",
  "author": "clixiya",
  "homepage": "https://github.com/clixiya/badlang",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/clixiya/badlang.git"
  },
  "bugs": {
    "url": "https://github.com/clixiya/badlang/issues"
  },
  "engines": {
    "node": ">=18.17.0"
  },
  "preferGlobal": true,
  "bin": {
    "bad": "./bin/bad.js",
    "bad-install": "./bin/bad-install.js"
  },
  "scripts": {
    "postinstall": "node scripts/postinstall.js",
    "install-binary": "node scripts/postinstall.js",
    "clean": "node scripts/clean.js",
    "test": "node --test test/*.test.js",
    "verify": "node ./bin/bad.js --help"
  },
  "files": [
    "bin",
    "lib",
    "scripts/postinstall.js",
    "scripts/clean.js",
    "README.md",
    "LICENSE"
  ],
  "keywords": [
    "bad",
    "api-testing",
    "cli",
    "native",
    "cross-platform",
    "runtime"
  ]
}
