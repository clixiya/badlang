    "Expect: Status Exact": {
        "prefix": "expstatus",
        "body": [
            "expect status ${1:200}"
        ],
        "description": "Assert exact status code"
    },
    "Expect: Status Comparator": {
        "prefix": "expstatusop",
        "body": [
            "expect status ${1|==,!=,<,<=,>,>=|} ${2:200}"
        ],
        "description": "Assert status using comparator"
    },
    "Expect: Status In List": {
        "prefix": "expstatusin",
        "body": [
            "expect status in [${1:200}, ${2:201}]"
        ],
        "description": "Assert status in allowed list"
    },
    "Expect: JSON Exists": {
        "prefix": "expjsonexists",
        "body": [
            "expect json.${1:path.to.field} exists"
        ],
        "description": "Assert JSON path exists"
    },
    "Expect: JSON Equals": {
        "prefix": "expjsoneq",
        "body": [
            "expect json.${1:path.to.field} == ${2:\"value\"}"
        ],
        "description": "Assert JSON value equals expected"
    },
    "Expect: JSON Contains": {
        "prefix": "expjsoncontains",
        "body": [
            "expect json.${1:path.to.field} contains \"${2:value}\""
        ],
        "description": "Assert JSON string contains value"
    },
    "Expect: JSON Starts With": {
        "prefix": "expjsonstarts",
        "body": [
            "expect json.${1:path.to.field} starts_with \"${2:prefix}\""
        ],
        "description": "Assert JSON string prefix"
    },
    "Expect: JSON Ends With": {
        "prefix": "expjsonends",
        "body": [
            "expect json.${1:path.to.field} ends_with \"${2:suffix}\""
        ],
        "description": "Assert JSON string suffix"
    },
    "Expect: JSON Regex": {
        "prefix": "expjsonregex",
        "body": [
            "expect json.${1:path.to.field} regex \"${2:^pattern$}\""
        ],
        "description": "Assert JSON value with regex"
    },
    "Expect: Time Under": {
        "prefix": "exptime",
        "body": [
            "expect time_ms < ${1:500}"
        ],
        "description": "Assert response duration"
    },
    "Assert: Status": {
        "prefix": "aststatus",
        "body": [
            "assert status ${1:200}"
        ],
        "description": "Alias assertion for status"
    },
    "Assert: JSON Exists": {
        "prefix": "astjson",
        "body": [
            "assert json.${1:path.to.field} exists"
        ],
        "description": "Alias assertion for JSON path"
    },
    "Assert: Time Under": {
        "prefix": "asttime",
        "body": [
            "assert time_ms < ${1:500}"
        ],
        "description": "Alias assertion for response duration"
    },
    "Guard: skip_if": {
        "prefix": "skipsafe",
        "body": [
            "skip_if ${1:status != 200} because \"${2:temporary issue}\""
        ],
        "description": "Skip flow when condition is true"
    },
    "Guard: fail_if": {
        "prefix": "failsafe",
        "body": [
