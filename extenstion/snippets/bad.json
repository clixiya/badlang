    "Hook: on_error": {
        "prefix": "bonerror",
        "body": [
            "on_error {",
            "\tprint \"${1:error detected}\"",
            "\t$0",
            "}"
        ],
        "description": "Handle assertion or network errors"
    },
    "Hook: on_assertion_error": {
        "prefix": "bonassert",
        "body": [
            "on_assertion_error {",
            "\tprint stats.assertions.failed",
            "\t$0",
            "}"
        ],
        "description": "Handle assertion failures"
    },
    "Hook: on_network_error": {
        "prefix": "bonnetwork",
        "body": [
            "on_network_error {",
            "\tprint stats.requests.network_failures",
            "\t$0",
            "}"
        ],
        "description": "Handle network failures"
    },
    "Hook: before_url": {
        "prefix": "bbeforeurl",
        "body": [
            "before_url \"${1:/*}\" {",
            "\ttime_start ${2:request_span}",
            "\t$0",
            "}"
        ],
        "description": "Run before matching URL"
    },
    "Hook: after_url": {
        "prefix": "bafterurl",
        "body": [
            "after_url \"${1:/*}\" {",
            "\ttime_stop ${2:request_span}",
            "\t$0",
            "}"
        ],
        "description": "Run after matching URL"
    },
    "Hook: on_url_error": {
        "prefix": "bonurlerror",
        "body": [
            "on_url_error \"${1:/*}\" {",
            "\tprint \"${2:url rule failed}\"",
            "\t$0",
            "}"
        ],
        "description": "Handle failures for matching URL"
    },
    "Request Template: Basic": {
        "prefix": "reqtpl",
        "body": [
            "request ${1:name} {",
            "\tmethod ${2|GET,POST,PUT,PATCH,DELETE|}",
            "\tpath \"${3:/path}\"",
            "\t$0",
            "}"
        ],
        "description": "Create a reusable request template"
    },
    "Request Template: Auth GET": {
        "prefix": "reqauthget",
        "body": [
            "request ${1:get_profile} {",
            "\tmethod GET",
            "\tpath \"${2:/me}\"",
            "\tbearer env ${3:API_TOKEN}",
            "\texpect status 200",
            "\t$0",
            "}"
        ],
        "description": "GET template with bearer auth"
    },
    "Request Template: JSON POST": {
        "prefix": "reqjsonpost",
        "body": [
            "request ${1:create_item} {",
            "\tmethod POST",
            "\tpath \"${2:/items}\"",
            "\theader Content-Type: \"application/json\"",
            "\tbody {",
            "\t\t${3:name}: \"${4:value}\"",
            "\t}",
            "\texpect status ${5:201}",
            "\t$0",
            "}"
        ],
        "description": "POST template with JSON body"
    },
    "Template Alias: Basic": {
        "prefix": "tplbasic",
        "body": [
            "template ${1:name} {",
            "\tmethod ${2|GET,POST,PUT,PATCH,DELETE|}",
            "\tpath \"${3:/path}\"",
            "\t$0",
            "}"
        ],
        "description": "Create template alias block"
    },
    "Export Request": {
        "prefix": "exportreq",
        "body": [
            "export request ${1:name} {",
            "\tmethod ${2|GET,POST,PUT,PATCH,DELETE|}",
            "\tpath \"${3:/path}\"",
            "\t$0",
            "}"
        ],
        "description": "Export a request template"
    },
    "Export Variable": {
        "prefix": "exportlet",
        "body": [
            "export let ${1:key} = ${2:env API_KEY}"
        ],
        "description": "Export a reusable variable"
    },
    "Send: Direct GET": {
        "prefix": "sendget",
        "body": [
            "send GET \"${1:/path}\"",
            "$0"
        ],
        "description": "Send simple GET request"
    },
    "Send: Direct POST JSON": {
        "prefix": "sendpostjson",
        "body": [
            "send POST \"${1:/path}\" {",
            "\theader Content-Type: \"application/json\"",
            "\tbody {",
            "\t\t${2:key}: \"${3:value}\"",
            "\t}",
            "\t$0",
            "}"
        ],
        "description": "Send POST with JSON body"
    },
    "Send: Direct PATCH": {
        "prefix": "sendpatch",
        "body": [
            "send PATCH \"${1:/path}\" {",
            "\tbody {",
            "\t\t${2:key}: \"${3:value}\"",
            "\t}",
            "\t$0",
            "}"
        ],
        "description": "Send PATCH with body"
    },
    "Send: Direct DELETE": {
        "prefix": "senddelete",
        "body": [
            "send DELETE \"${1:/path}\"",
            "$0"
        ],
        "description": "Send DELETE request"
    },
    "Send: Request Template": {
        "prefix": "sendreq",
        "body": [
            "send req ${1:template_name}",
            "$0"
        ],
        "description": "Execute request template"
    },
    "Send: Template With Override": {
        "prefix": "sendtplwith",
        "body": [
            "send template ${1:template_name} with {",
            "\tpath \"${2:/override}\"",
            "\t$0",
            "}"
        ],
        "description": "Run template with inline overrides"
    },
    "Send: Template With Body Merge": {
        "prefix": "sendtplmerge",
        "body": [
            "send req ${1:template_name} with {",
            "\tbody_merge true",
            "\tbody {",
            "\t\t${2:key}: \"${3:value}\"",
            "\t}",
            "\t$0",
            "}"
        ],
        "description": "Run template and merge override body"
    },
    "Send: With Headers": {
        "prefix": "sendheaders",
        "body": [
            "send ${1|GET,POST,PUT,PATCH,DELETE|} \"${2:/path}\" {",
            "\theader ${3:Accept}: \"${4:application/json}\"",
            "\theader ${5:X-Request-Id}: \"${6:req-123}\"",
            "\t$0",
            "}"
        ],
        "description": "Send request with custom headers"
    },
    "Send: With Timeout": {
        "prefix": "sendtimeout",
        "body": [
            "send ${1|GET,POST,PUT,PATCH,DELETE|} \"${2:/path}\" {",
            "\ttimeout ${3:5000}",
            "\t$0",
            "}"
        ],
        "description": "Send request with per-call timeout"
    },
    "Send: With Retry Controls": {
        "prefix": "sendretry",
        "body": [
            "send ${1|GET,POST,PUT,PATCH,DELETE|} \"${2:/path}\" {",
            "\tretry ${3:2}",
            "\tretry_delay_ms ${4:200}",
            "\tretry_backoff ${5:2}",
            "\tretry_jitter_ms ${6:100}",
            "\t$0",
            "}"
        ],
        "description": "Send request with retry settings"
    },
    "Send: Bearer Shortcut": {
        "prefix": "sendbearer",
        "body": [
            "send ${1|GET,POST,PUT,PATCH,DELETE|} \"${2:/path}\" {",
            "\tbearer ${3:env API_TOKEN}",
            "\t$0",
            "}"
        ],
        "description": "Send request with bearer token"
    },
