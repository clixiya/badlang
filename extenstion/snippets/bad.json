        "description": "Insert common assertion bundle"
    },
    "Expect: Success Family": {
        "prefix": "exp2xx",
        "body": [
            "expect status >= 200",
            "expect status < 300",
            "$0"
        ],
        "description": "Assert status is in 2xx family"
