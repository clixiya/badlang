    "Scenario: Smoke Health": {
        "prefix": "scnsmoke",
        "body": [
            "test \"${1:health endpoint}\" {",
            "\tsend GET \"${2:/health}\"",
            "\texpect status 200",
            "\texpect time_ms < ${3:300}",
            "\t$0",
            "}"
        ],
        "description": "Quick smoke test scenario"
    },
    "Scenario: Auth Login": {
        "prefix": "scnauth",
        "body": [
            "test \"${1:login succeeds}\" {",
            "\tsend POST \"${2:/auth/login}\" {",
            "\t\tbody {",
            "\t\t\temail: \"${3:user@example.com}\"",
            "\t\t\tpassword: \"${4:secret}\"",
            "\t\t}",
            "\t}",
            "\texpect status 200",
            "\texpect json.${5:token} exists",
            "\t$0",
            "}"
        ],
        "description": "Authentication test scenario"
    },
    "Scenario: CRUD Flow": {
        "prefix": "scncrud",
        "body": [
            "group \"${1:crud flow}\" {",
            "\ttest \"create\" {",
            "\t\tsend POST \"${2:/items}\" {",
            "\t\t\tbody { ${3:name}: \"${4:value}\" }",
            "\t\t}",
            "\t\texpect status 201",
            "\t}",
            "",
            "\ttest \"list\" {",
            "\t\tsend GET \"${2:/items}\"",
            "\t\texpect status 200",
            "\t}",
            "",
            "\ttest \"delete\" {",
            "\t\tsend DELETE \"${2:/items}/${5:id}\"",
            "\t\texpect status ${6:204}",
            "\t}",
            "\t$0",
            "}"
        ],
        "description": "Create/list/delete end-to-end flow"
    },
    "Scenario: Retry Network": {
        "prefix": "scnretry",
        "body": [
            "test \"${1:retry transient failures}\" {",
            "\tsend GET \"${2:/flaky}\" {",
            "\t\tretry ${3:3}",
            "\t\tretry_delay_ms ${4:250}",
            "\t\tretry_backoff ${5:2}",
            "\t\tretry_jitter_ms ${6:100}",
            "\t}",
            "\texpect status 200",
            "\t$0",
            "}"
        ],
        "description": "Network retry scenario"
    },
    "Scenario: Rate Limit": {
        "prefix": "scnratelimit",
        "body": [
            "test \"${1:rate limit response}\" {",
            "\tsend GET \"${2:/rate-limited}\"",
            "\texpect status ${3:429}",
            "\texpect json.${4:error} contains \"${5:rate}\"",
            "\t$0",
            "}"
        ],
        "description": "Validate 429 and error shape"
    },
    "Scenario: Pagination": {
        "prefix": "scnpaging",
        "body": [
            "test \"${1:pagination returns next cursor}\" {",
            "\tsend GET \"${2:/items?page=1&limit=20}\"",
            "\texpect status 200",
            "\texpect json.${3:data} exists",
            "\texpect json.${4:next_cursor} exists",
            "\t$0",
            "}"
        ],
        "description": "Pagination response scenario"
    },
    "Scenario: Error Hooks": {
        "prefix": "scnhooks",
        "body": [
            "on_error {",
            "\tprint \"error captured\"",
            "\tprint stats.runtime.soft_errors",
            "}",
            "",
            "on_assertion_error {",
            "\tprint stats.assertions.failed",
            "}",
            "",
            "on_network_error {",
            "\tprint stats.requests.network_failures",
            "}",
            "",
            "$0"
        ],
        "description": "Common error hooks bundle"
    },
    "Scenario: URL Hooks": {
        "prefix": "scnurlhooks",
        "body": [
            "before_url \"${1:/api/*}\" {",
            "\ttime_start ${2:api_call}",
            "}",
            "",
            "after_url \"${1:/api/*}\" {",
            "\ttime_stop ${2:api_call}",
            "\tprint time ${2:api_call}",
            "}",
            "",
            "on_url_error \"${1:/api/*}\" {",
            "\tprint \"api call failed\"",
            "}",
            "",
            "$0"
        ],
        "description": "URL lifecycle hooks bundle"
    },
