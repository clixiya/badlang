{
    "Test: Basic": {
        "prefix": "btest",
        "body": [
            "test \"${1:name}\" {",
            "\t$0",
            "}"
        ],
        "description": "Create a standard test block"
    },
    "Test: Focused": {
        "prefix": "btestonly",
