        ],
        "description": "Fail flow when condition is true"
    },
    "Guard: Runtime Soft Errors": {
        "prefix": "guardsoft",
        "body": [
            "fail_if stats.runtime.soft_errors > ${1:0} because \"${2:runtime issue}\""
        ],
        "description": "Fail on runtime soft errors"
